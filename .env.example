# ============================================================
# TAP TYCOON — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# ── Server ───────────────────────────────────────────────────
PORT=3000

# The origin of your frontend (used for CORS).
# Examples:
#   https://tap-tycoon.vercel.app
#   https://yourdomain.com
CLIENT_ORIGIN=https://your-frontend-domain.com

# ── PayPal ───────────────────────────────────────────────────
# Get from: https://developer.paypal.com
# → Apps & Credentials → Live tab → Create App → Tap Tycoon
# → copy Client ID and Secret
#
# Your PayPal account: ariunjargal.ts15@gmail.com
# Upgrade to Business first: https://www.paypal.com/business
PAYPAL_CLIENT_ID=YOUR_LIVE_PAYPAL_CLIENT_ID
PAYPAL_CLIENT_SECRET=YOUR_LIVE_PAYPAL_CLIENT_SECRET

# After deploying, configure a webhook in PayPal dashboard:
#   URL: https://your-api-domain.com/api/paypal-webhook
#   Events: PAYMENT.CAPTURE.COMPLETED
# Then paste the Webhook ID here:
PAYPAL_WEBHOOK_ID=YOUR_PAYPAL_WEBHOOK_ID

# For production use the live API:
PAYPAL_API_BASE=https://api-m.paypal.com
# For sandbox/testing use:
# PAYPAL_API_BASE=https://api-m.sandbox.paypal.com

# ── Firebase ─────────────────────────────────────────────────
# Get from: https://console.firebase.google.com
# → Project Settings → Service Accounts → Generate new private key
# Paste the entire downloaded JSON as a single line here.
# Tip: cat serviceAccount.json | tr -d '\n'
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}
