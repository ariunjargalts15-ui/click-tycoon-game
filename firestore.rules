// ============================================================
// Tap Tycoon — Firestore Security Rules
//
// HOW TO APPLY:
//   1. Go to https://console.firebase.google.com
//   2. Select your project
//   3. Firestore Database → Rules tab
//   4. Paste this entire file and click Publish
// ============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── users/{userId} ─────────────────────────────────────────
    // Clients can READ their own document (to restore purchases on login).
    // Clients can WRITE only the "progress" subcollection (game state).
    // All pack/badge/purchase fields are WRITE-LOCKED on the main doc —
    // only the backend Admin SDK (bypass security rules) can write them.
    match /users/{userId} {

      // Allow authenticated users to read their own document
      allow read: if request.auth != null && request.auth.uid == userId;

      // DENY all direct client writes to the main user document.
      // Pack fields (starterPackPurchased, legendPackPurchased, badge, etc.)
      // can only be written by the backend via Admin SDK.
      allow write: if false;

      // ── users/{userId}/progress/gameState ──────────────────
      // Clients CAN write their own game progress (coins, level, upgrades).
      // They CANNOT touch pack fields because those only live on the parent doc.
      match /progress/gameState {
        allow read:  if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && request.auth.uid == userId
                     // Prevent the client from sneaking in pack fields
                     && !request.resource.data.keys().hasAny([
                          'starterPackPurchased',
                          'legendPackPurchased',
                          'packType',
                          'permanentAdsRemoved',
                          'tapIncomeMultiplier',
                          'autoIncomeMultiplier',
                          'badge',
                          'goldenButtonChanceMult'
                        ]);
      }
    }

    // ── purchases/{orderId} ────────────────────────────────────
    // Users can read their own purchase records (for support / restore).
    // Only backend can write (idempotency guard).
    match /purchases/{orderId} {
      allow read:  if request.auth != null
                   && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
